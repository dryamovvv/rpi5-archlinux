#!/bin/bash

# Example build configuration for src/main.sh and dist/bin/rpi5-archlinux-image.

BUILD_FILESYSTEM="btrfs"  # btrfs (with snapper rollback) | ext4 (fallback)
BUILD_IMAGE_PATH="$BUILD_PROJECT_ROOT/dist/images/archlinux-rpi5-aarch64.img"
BUILD_IMAGE_SIZE="4g"
BUILD_IMAGE_SHRINK_MARGIN="256M"
BUILD_MOUNT_ROOT="/mnt/arch_build"
BUILD_MOUNT_BOOT="$BUILD_MOUNT_ROOT/boot"

BUILD_QEMU_IMAGE_PATH="$BUILD_PROJECT_ROOT/dist/images/archlinux-qemu-aarch64.img"
BUILD_QEMU_BOOT_DIR="$BUILD_PROJECT_ROOT/dist/images/qemu-boot"
BUILD_QEMU_MOUNT_ROOT="/mnt/arch_qemu_build"
BUILD_QEMU_CPU="cortex-a72"
BUILD_QEMU_SMP="4"
BUILD_QEMU_MEMORY="2048"
BUILD_QEMU_SSH_HOST_PORT="2222"
BUILD_QEMU_KERNEL_CMDLINE="root=/dev/vda2 rw rootwait console=ttyAMA0"
BUILD_QEMU_ROOTFLAGS="subvol=@"

BUILD_HOSTNAME="archlinux-develop"
# SSH пользователь для AllowUsers (root всегда разрешён); пусто = только root
BUILD_SSH_USER=""
# PermitRootLogin: yes (password+key, default) | prohibit-password (key only) | no
BUILD_SSH_PERMIT_ROOT_LOGIN="yes"
# Публичный SSH-ключ для root (нужен при PermitRootLogin prohibit-password)
BUILD_ROOT_SSH_KEY=""
# Дополнительные пользователи для AllowUsers (через пробел), оставить пустым если не нужны
BUILD_SSH_ALLOW_USERS=""
BUILD_ROOT_PASSWORD="root"
BUILD_TIMEZONE="Europe/Moscow"
BUILD_MKINITCPIO_HOOKS="HOOKS=(base systemd autodetect modconf kms keyboard keymap sd-vconsole block filesystems fsck)"
# Initramfs compression: "gzip" (default), "cat" (faster dev builds, no compression)
BUILD_MKINITCPIO_COMPRESSION="gzip"
# Image shrink: controlled by "image_shrink" in BUILD_MODULES (line 49).
# To skip shrinking, remove "image_shrink" from BUILD_MODULES.
# ZRAM compression: 0=disabled, 1=enabled via systemd-zram-generator
BUILD_ENABLE_ZRAM=1
# ZRAM size: value in MEGABYTES (NOT with G suffix — fasteval treats G as 10^9, then *1024*1024 double-converts)
# Use "4096" for 4 GiB, "2048" for 2 GiB, or expression like "min(ram / 2, 4096)"
BUILD_ZRAM_SIZE="2048"
# Swapfile on btrfs (secondary swap, ZRAM fills first): size like "16g" or "" to disable
BUILD_SWAPFILE_SIZE="16G"
# Wi-Fi support: 0=disabled, 1=enable wpa_supplicant and remove disable-wifi overlay
BUILD_ENABLE_WIFI=0
# Firewall (nftables): 1=enabled (default), 0=disabled — SSH+80+443+estab+lo, rest denied
BUILD_ENABLE_FIREWALL=1
# Periodic TRIM for NVMe/SSD (fstrim.timer): 1=enabled (default), 0=disabled
# BTRFS discard=async is kernel default since 6.2 — fstrim is complementary, not replacement
BUILD_ENABLE_FSTRIM=1
# Disk encryption via LUKS (btrfs only): 1=enabled, 0=disabled (default)
# WARNING: requires pre-built mkinitcpio-systemd-extras AUR package at BUILD_AUR_PKG_URL
BUILD_ENABLE_ENCRYPTION=0
# LUKS passphrase for disk encryption (required when BUILD_ENABLE_ENCRYPTION=1)
BUILD_LUKS_PASSWORD=""
# LUKS unlock mode: "keyboard" (local console, default), "ssh" (remote via tinysshd in initramfs)
# or "telegram" (poll Telegram Bot API for passphrase — requires BUILD_TELEGRAM_BOT_TOKEN + BUILD_TELEGRAM_CHAT_ID)
BUILD_LUKS_UNLOCK_MODE="keyboard"
# URL to pre-built mkinitcpio-systemd-extras AUR package (*.pkg.tar.zst) — required for ssh mode
BUILD_AUR_PKG_URL=""
# Telegram Bot API credentials for LUKS unlock (required when BUILD_LUKS_UNLOCK_MODE=telegram)
BUILD_TELEGRAM_BOT_TOKEN=""
BUILD_TELEGRAM_CHAT_ID=""

BUILD_MODULES=(
    "disk_image"
    "base_system"
    "boot_config"
    "services"
    "release_validation"
    "image_shrink"
)

BUILD_PACKAGES=(
    "base"
    "archlinuxarm-keyring"
    "pacman-mirrorlist"
    "linux-rpi-16k"
    "raspberrypi-bootloader"
    "raspberrypi-utils"
    "firmware-raspberrypi"
    "linux-firmware"
    "wireless-regdb"
    "sudo"
    "openssh"
    # Quality-of-life
    "git"
    "vim"
    "htop"
    "tmux"
    "bash-completion"
    "man-db"
    "man-pages"
    "logrotate"
    # Hardware
    "i2c-tools"
    "cpupower"
    "rng-tools"
    # Network & security
    "fail2ban"
    "wpa_supplicant"
    "avahi"
    "s-tui"
    "stress-ng"
    "fio"
    "hdparm"
    "btop"
    "rpi5-eeprom"
    "rpi-imager"
    "flashrom"
    "nvme-cli"
    # Btrfs + snapper
    "btrfs-progs"
    "snapper"
    "snap-pac"
    "btrbk"
    "inetutils"
    "which"
    "pacman-contrib"
    # ZRAM swap compression
    "zram-generator"
    # MCP server (uvx arch-ops-server) for remote AI diagnostics
    "uv"
)

# Journal gateway (HTTP logs on port 19531): 1=enabled (default), 0=disabled
# WARNING: port 19531 is world-readable — disable on internet-facing hosts
BUILD_ENABLE_JOURNAL_GATEWAY=1
# MCP server (arch-ops-server on port 8080, Bearer auth): 1=enabled (default), 0=disabled
BUILD_ENABLE_MCP_SERVER=1

# Firewall (nftables): 1=enabled (default), 0=disabled. Allows SSH+HTTP+HTTPS, drops rest.
BUILD_ENABLE_FIREWALL=1

# EEPROM update channel: "default" (stable) or "latest" (newer, +performance)
BUILD_EEPROM_CHANNEL="latest"

BUILD_QEMU_MODULES=(
    "disk_image"
    "base_system"
    "qemu_boot_config"
    "services"
    "image_shrink"
)

BUILD_QEMU_PACKAGES=(
    "base"
    "archlinuxarm-keyring"
    "pacman-mirrorlist"
    "linux-aarch64"
    "sudo"
    "openssh"
    # Quality-of-life
    "git"
    "vim"
    "htop"
    "tmux"
    "bash-completion"
    "man-db"
    "man-pages"
    "logrotate"
    # Hardware
    "i2c-tools"
    "cpupower"
    "rng-tools"
    # Network & security
    "fail2ban"
    "wpa_supplicant"
    "avahi"
    "s-tui"
    "stress-ng"
    "fio"
    "hdparm"
    "btop"
    "nvme-cli"
    # Btrfs + snapper
    "btrfs-progs"
    "snapper"
    "snap-pac"
    "btrbk"
    # ZRAM swap compression
    "zram-generator"
    # MCP server (uvx arch-ops-server) for remote AI diagnostics
    "uv"
)
